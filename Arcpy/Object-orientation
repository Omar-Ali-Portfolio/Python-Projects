# Question 3
 
class Device():
    def __init__(self, id):
        self.id = id
 
    def scan(self):
        print(self.id, end='')
 
 
class Phone(Device):
    def __init__(self, id, number):
        super().__init__(id)
        self.number = number
        self.year = 1900
 
    def scan(self):
        super().scan()
        print(' ', self.number)
 
    def call(self, num):
        print(f'Calling {num}')
 
    def __str__(self):
        return f'Phone: {self.id} {self.number}'
 
 
class Computer(Device):
    def __init__(self, id, cpu, ram):
        super().__init__(id)
        self.cpu = cpu
        self.ram = ram
 
    def print(self, doc):
        print(f'Printing {doc} ...')
 
    def __str__(self):
        return f'Computer: {self.id}'
 
 
comp_1 = Computer('C1234', 'M2', 16)
# no output, works fine
 
dv = Device('RandomDevice123456')
# no output, works fine too
# but Device isnt abstract so you can make a generic one which shouldnt be allowed
 
 
# Question 4
 
from abc import ABC, abstractmethod
 
 
class Player(ABC):
    @abstractmethod
    def play(self):
        pass
 
 
class Radio(Player):
    def play(self):
        print("Playing music from the radio...")
 
 
class Tape(Player):
    def play(self):
        print("Playing music from the cassette tape...")
 
 
class CD(Player):
    def play(self):
        print("Playing music from the CD...")
 
 
# added bluetooth from page 43
class Bluetooth(Player):
    def play(self):
        print("Playing music via Bluetooth...")
 
 
class Boombox:
    def __init__(self):
        self.players = {
            "radio": Radio(),
            "tape": Tape(),
            "cd": CD(),
            "bluetooth": Bluetooth()
        }
        self.current = self.players["radio"]
 
    def set_player(self, name):
        self.current = self.players[name]
 
    def press_play(self):
        self.current.play()
 
 
boombox = Boombox()
 
boombox.set_player("cd")
boombox.press_play()
# Playing music from the CD...
 
boombox.set_player("radio")
boombox.press_play()
# Playing music from the radio...
 
boombox.set_player("bluetooth")
boombox.press_play()
# Playing music via Bluetooth...
 
