# Question 1
 
class Person:
    def __init__(self, name, id, unit, title=None):
        self.name = name
        self.id = id
        self.unit = unit
        self.title = title
        self.devices = []
 
    def report(self):
        for d in self.devices:
            print(d)
 
    def get_device(self, device):
        self.devices.append(device)
 
    def __str__(self):
        return f'Name: {self.name} | Unit: {self.unit}'
 
 
class Phone:
    def __init__(self, id, number):
        self.id = id
        self.number = number
        self.year = 1900
 
    def scan(self):
        print(self.id, self.number)
 
    def call(self, num):
        print(f'Calling {num}')
 
    def __str__(self):
        return f'Phone: {self.id} {self.number}'
 
 
class Computer:
    def __init__(self, id, cpu, ram):
        self.id = id
        self.cpu = cpu
        self.ram = ram
 
    def scan(self):
        print(self.id)
 
    def print(self, doc):
        print(f'Printing {doc} ...')
 
    def __str__(self):
        return f'Computer: {self.id}'
 
 
me = Person('Actual Fun', 'X1276334', 'Tech', 'Data Analyst')
phone_1 = Phone('PH1234', '6141234567')
comp_1 = Computer('C1234', 'M2', 16)
me.get_device(phone_1)
